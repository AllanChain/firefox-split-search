{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "split-search@example.com"
    }
  },
  "name": "Split Search",
  "version": "1.0.0",
  "description": "Search two engines simultaneously in Firefox's native split view",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "https://split-search.invalid/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "chrome_settings_overrides": {
    "search_provider": {
      "name": "Split Search",
      "keyword": "@split",
      "search_url": "https://split-search.invalid/?q={searchTerms}"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "experiment_apis": {
    "splitView": {
      "schema": "experiment/splitview/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["splitView"]],
        "script": "experiment/splitview/api.js"
      }
    }
  }
}
